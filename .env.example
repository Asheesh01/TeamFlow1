# Server
PORT=5000
NODE_ENV=production

# MySQL (Railway provides these automatically when you add MySQL plugin)
DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=railway

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL (Railway public domain, used for CORS)
# Example: https://teamflow-production.up.railway.app
FRONTEND_URL=https://your-app.up.railway.app
